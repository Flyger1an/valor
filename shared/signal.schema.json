{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ValorRVSignal",
  "description": "Locked signal contract emitted by Valor (TS) and consumed by the Evolver (Python).",
  "type": "object",
  "required": [
    "signal_id", "timestamp", "type", "assets", "zscore", "spread_value",
    "expected_convergence_hours", "risk_score", "confidence", "regime"
  ],
  "additionalProperties": true,
  "properties": {
    "signal_id": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "type": {
      "type": "string",
      "enum": ["cointegration_spread", "funding_arb", "basis_trade", "stat_arb_pair", "triangular"]
    },
    "assets": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "zscore": { "type": "number" },
    "spread_value": { "type": "number" },
    "expected_convergence_hours": { "type": "number", "exclusiveMinimum": 0 },
    "risk_score": { "type": "number", "minimum": 0, "maximum": 1, "description": "0=safest, 1=riskiest" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "regime": { "type": "string" },
    "metadata": { "type": "object" }
  }
}
