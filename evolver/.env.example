# ---- LLM backbone ----
OPENAI_API_KEY=
FAST_MODEL=gpt-5-mini          # inner loop (analysis + paper decision) — cheap/fast
STRONG_MODEL=gpt-5.5           # outer loop (Critic/Optimizer) only
LLM_TEMPERATURE=               # leave blank for reasoning models (gpt-5.x reject non-default)

# ---- infra ----
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://valor:valor@localhost:5432/evolver
SIGNAL_STREAM=valor.signals
SIGNAL_GROUP=evolver
MLFLOW_TRACKING_URI=http://localhost:5001   # host port; in Docker the services use http://mlflow:5000
EVOLVER_LEDGER=.evolver/ledger.jsonl
EVOLVER_AUDIT=.evolver/audit.jsonl

# ---- LangSmith tracing (optional, zero-code) ----
# Set both to auto-trace every LLM call. Key from smith.langchain.com.
# Passed to the containers via env_file, so just add your key here and rebuild.
LANGCHAIN_TRACING_V2=
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=valor-evolver

# ---- Telegram (roles by allowlist) ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_IDS=        # comma-separated; full control (/approve /tweak /kill)
TELEGRAM_OBSERVER_CHAT_IDS=     # comma-separated; read-only + /feedback

# ---- risk (mirrors DEFAULT_PAPER_LIMITS; the hard envelope) ----
PAPER_CAPITAL=100000
MAX_LEVERAGE=5.0
MAX_POSITION_PCT=0.25
MAX_DD_KILL=0.15
BASE_RISK_PER_TRADE=0.0075
