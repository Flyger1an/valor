# Local data
DATABASE_URL="file:./.valor/valor.sqlite"
VALOR_REFRESH_INTERVAL_MS=300000
VALOR_STALE_DATA_MS=300000
POSTGRES_USER=valor
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_DB=valor
REDIS_URL=redis://redis:6379

# Ops API guard. Production mutating/spendful endpoints fail closed unless this
# is set and sent as X-Valor-Ops-Secret or Authorization: Bearer <secret>.
VALOR_OPS_SECRET=
# Browser session auth. Production dashboard pages fail closed unless the
# session secret and password hash are set.
VALOR_SESSION_SECRET=
VALOR_ADMIN_PASSWORD_HASH=
VALOR_SESSION_TTL_SECONDS=43200
VALOR_REQUIRE_BROWSER_AUTH=false
# Keep false in production unless the dashboard/API is behind a private network
# and you explicitly want read-only ops APIs exposed without the ops header.
VALOR_PUBLIC_READ_APIS=false

# Public/free data adapters. Defaults are safe/local; set true/public for live OKX primary + Binance fallback.
# Options: false | sample | coingecko | binance | true | public | live
ENABLE_PUBLIC_MARKET_FETCH=false
COINGECKO_DEMO_API_KEY=

# LLM analyst copilot. This is RAG/extraction/explanation only, never trading authority.
LLM_API_ENABLED=false
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-5.5
LLM_TIMEOUT_MS=20000
LLM_MAX_CONTEXT_CHARS=24000
LLM_TEMPERATURE=

# Telegram alerts and bot commands
TELEGRAM_BOT_TOKEN=
TELEGRAM_AUTHORIZED_CHAT_IDS=
# Strongly recommended when exposing the webhook. Requests without the matching
# X-Telegram-Bot-Api-Secret-Token header are rejected when this is set.
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_DRY_RUN=true
ALERT_QUIET_HOURS_ENABLED=false
ALERT_QUIET_HOURS_START=22
ALERT_QUIET_HOURS_END=7
ALERT_ESCALATION_MINUTES=15

# Evidence-loop scheduler. Alert sending is opt-in; default cycles are dry-run.
VALOR_APP_URL=http://127.0.0.1:3000
VALOR_EVOLVER_EVIDENCE_DIR=
SCHEDULER_INTERVAL_MS=300000
SCHEDULER_RUN_ON_START=true
SCHEDULER_RUN_ONCE=false
SCHEDULER_SEND_ALERTS=false
SCHEDULER_ALERT_LIMIT=3
SCHEDULER_STALE_AFTER_MS=

# Twilio SMS fallback for CRITICAL/BLACK only
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBERS=
TWILIO_DRY_RUN=true

# Persistent kill switch
KILL_SWITCH_STATE_PATH=.valor/kill-switch.json

# Live trading is intentionally disabled unless every guardrail is deliberately configured.
ENABLE_LIVE_TRADING=false
LIVE_TRADING_ENABLED=false
REQUIRE_MANUAL_LIVE_CONFIRMATION=true
LIVE_TRADING_DRY_RUN=true
LIVE_KILL_SWITCH=true
LIVE_MAX_TRADE_USD=250
LIVE_DAILY_LOSS_LIMIT_USD=100
LIVE_MAX_LEVERAGE=1
LIVE_ALLOWED_VENUES=coinbase,kraken
LIVE_ALLOWED_ASSETS=BTC,ETH,USDC,USD
