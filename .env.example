# Local data
DATABASE_URL="file:./.valor/valor.sqlite"
VALOR_REFRESH_INTERVAL_MS=300000
POSTGRES_USER=valor
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_DB=valor
REDIS_URL=redis://redis:6379

# Public/free data adapters. Default in .env.example is live fetch on.
# Options: false (fixtures only) | binance | coingecko | true (OKX primary, Binance fallback)
ENABLE_PUBLIC_MARKET_FETCH=true
VALOR_STALE_DATA_MS=300000
COINGECKO_DEMO_API_KEY=

# LLM analyst copilot. Offline RAG works without keys. Live LLM needs BOTH flags below.
# This is RAG/extraction/explanation only, never trading authority.
LLM_API_ENABLED=false
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4.1
LLM_TIMEOUT_MS=20000
LLM_MAX_CONTEXT_CHARS=24000

# Telegram alerts and bot commands
TELEGRAM_BOT_TOKEN=
TELEGRAM_AUTHORIZED_CHAT_IDS=
ALERT_QUIET_HOURS_ENABLED=false
ALERT_QUIET_HOURS_START=22
ALERT_QUIET_HOURS_END=7
ALERT_ESCALATION_MINUTES=15

# Twilio SMS fallback for CRITICAL/BLACK only
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_TO_NUMBERS=
TWILIO_DRY_RUN=true

# Persistent kill switch
KILL_SWITCH_STATE_PATH=.valor/kill-switch.json

# Live trading is intentionally disabled unless every guardrail is deliberately configured.
ENABLE_LIVE_TRADING=false
LIVE_TRADING_ENABLED=false
REQUIRE_MANUAL_LIVE_CONFIRMATION=true
LIVE_TRADING_DRY_RUN=true
LIVE_KILL_SWITCH=true
LIVE_MAX_TRADE_USD=250
LIVE_DAILY_LOSS_LIMIT_USD=100
LIVE_MAX_LEVERAGE=1
LIVE_ALLOWED_VENUES=coinbase,kraken
LIVE_ALLOWED_ASSETS=BTC,ETH,USDC,USD
